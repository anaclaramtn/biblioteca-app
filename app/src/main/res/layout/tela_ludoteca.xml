<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".LudotecaActivity">

    <!-- Conteudo principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/background_header">

            <ImageView
                android:id="@+id/btnVoltar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_leftarrow"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="16dp"
                android:text="LUDOTECA"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- TABS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="16dp"
            android:background="@android:color/transparent">

            <TextView
                android:id="@+id/tabJogos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="10dp"
                android:text="Jogos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#E3F2FD"
                android:textColor="#002D5E" />

            <TextView
                android:id="@+id/tabSalas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="10dp"
                android:text="Salas"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="#FFFFFF"
                android:textColor="#000000" />

        </LinearLayout>

        <!-- CONTEUDO JOGOS -->
        <ScrollView
            android:id="@+id/containerJogos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- UNO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:layout_margin="8dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvUno"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="UNO"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivUno" />

                        <TextView
                            android:id="@+id/tvStatusUno"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Disponível"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/tvUno"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivUno" />

                        <Button
                            android:id="@+id/btnAlugarUno"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALUGAR"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:stateListAnimator="@null"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="#000000"
                            app:strokeWidth="1dp"
                            app:layout_constraintTop_toBottomOf="@id/tvStatusUno"
                            app:layout_constraintStart_toStartOf="parent"
                            android:onClick="onAlugarClick"/>

                        <ImageView
                            android:id="@+id/ivUno"
                            android:layout_width="100dp"
                            android:layout_height="134dp"
                            android:src="@drawable/logo"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:src="@drawable/uno" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- WAR -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:layout_margin="8dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvWar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="WAR"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivWar" />

                        <TextView
                            android:id="@+id/tvStatusWar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Indisponível"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/tvWar"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/ivWar" />

                        <Button
                            android:id="@+id/btnAlugarWar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALUGAR"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:stateListAnimator="@null"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="#000000"
                            app:strokeWidth="1dp"
                            app:layout_constraintTop_toBottomOf="@id/tvStatusWar"
                            app:layout_constraintStart_toStartOf="parent"
                            android:onClick="onAlugarClick"/>

                        <ImageView
                            android:id="@+id/ivWar"
                            android:layout_width="100dp"
                            android:layout_height="134dp"
                            android:src="@drawable/logo"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:src="@drawable/war" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- CONTEUDO SALAS -->
        <ScrollView
            android:id="@+id/containerSalas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- SALA 01 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:layout_margin="8dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvSala01"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="SALA 01"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:id="@+id/tvStatusSala01"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Disponível\nCapacidade: 10 pessoas"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/tvSala01"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <Button
                            android:id="@+id/btnReservar01"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RESERVAR"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:stateListAnimator="@null"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="#000000"
                            app:strokeWidth="1dp"
                            app:layout_constraintTop_toBottomOf="@id/tvStatusSala01"
                            app:layout_constraintStart_toStartOf="parent"
                            android:onClick="onReservarClick"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- SALA 02 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:layout_margin="8dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvSala02"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="SALA 02"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:id="@+id/tvStatusSala02"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Indisponível\nCapacidade: 12 pessoas"
                            android:textSize="14sp"
                            app:layout_constraintTop_toBottomOf="@id/tvSala02"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <Button
                            android:id="@+id/btnReservar02"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RESERVAR"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#FFFFFF"
                            android:textColor="#000000"
                            android:stateListAnimator="@null"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            app:strokeColor="#000000"
                            app:strokeWidth="1dp"
                            app:layout_constraintTop_toBottomOf="@id/tvStatusSala02"
                            app:layout_constraintStart_toStartOf="parent"
                            android:onClick="onReservarClick"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <include layout="@layout/navbar_layout"/>

</LinearLayout>