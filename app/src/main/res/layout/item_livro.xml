<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">
    <ImageView android:id="@+id/imgCapa" android:layout_width="match_parent" android:layout_height="180dp" android:scaleType="centerCrop" android:background="#EEE"/>
    <TextView android:id="@+id/txtTituloLivro" android:layout_width="match_parent" android:layout_height="wrap_content" android:ellipsize="end" android:maxLines="1" android:textStyle="bold" />
    <TextView android:id="@+id/txtAutor" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="12sp" />
</LinearLayout>