<?xml version="1.0" encoding="utf-8"?>

<!--
padrao para as telas:
sera utilizado o mesmo backgroudn em todas as telas (arquivo xml contido na pasta drawable)
padrao de id:
tipo do objeto + função
exemplo: campo para colocar email é um EditText -> id: EditTextEmail
-->

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <TextView
            android:id="@+id/TextViewTituloCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="24dp"
            android:layout_marginBottom="24dp"
            android:text="Criar Conta"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/TextViewLabelNome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome Completo"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/EditTextNomeCompleto"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/background_campo_input"
            android:hint="Digite seu nome completo"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#212121"
            android:textColorHint="#90A4AE"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/TextViewLabelEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-mail"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/EditTextEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/background_campo_input"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#212121"
            android:textColorHint="#90A4AE"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/TextViewRequisitosNovaSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#E8F4F4"
            android:padding="12dp"
            android:text="Requisitos da senha:\n• Pelo menos 1 número\n• Pelo menos 1 letra minúscula\n• Pelo menos 1 letra maiúscula"
            android:textColor="#3A7C7C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/TextViewLabelSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senha"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/EditTextSenha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/background_campo_input"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="52dp"
                android:textColor="#212121"
                android:textColorHint="#90A4AE"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/ImageButtonToggleVisibilidadeSenha"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mostrar ou ocultar senha"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_view" />
        </FrameLayout>

        <TextView
            android:id="@+id/TextViewLabelConfirmarSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmar Senha"
            android:textColor="#37474F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/EditTextConfirmarSenha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/background_campo_input"
                android:hint="Confirme sua senha"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="52dp"
                android:textColor="#212121"
                android:textColorHint="#90A4AE"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/ImageButtonToggleVisibilidadeConfirmarSenha"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mostrar ou ocultar confirmação de senha"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_view" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/ButtonCriar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="20dp"
            android:text="Criar"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#6F8FAF"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/TextViewJaTemConta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:clickable="true"
            android:focusable="true"
            android:text="Já tem uma conta? Entrar"
            android:textColor="#6F8FAF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>