<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".PerfilActivity">

    <!-- Conteudo principal -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_header">

                <ImageView
                    android:id="@+id/btnVoltar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_leftarrow"
                    app:tint="#FFFFFF" />

                <TextView
                    android:id="@+id/txtTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="16dp"
                    android:text="PERFIL"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <!-- INFO USUARIO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thiago Narak Carvalho"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="narak@unifor.com"
                    android:textSize="16sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <!-- SEÇÃO: LIVROS ALUGADOS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:text="Livros Alugados no Momento"
                android:textStyle="bold"
                android:textSize="14sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                android:layout_margin="8dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvTituloLivro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Dom Quixote"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/ivCapaLivro" />

                    <TextView
                        android:id="@+id/tvDevolucaoLivro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Devolução: 05/04/2026"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/tvTituloLivro"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/ivCapaLivro" />

                    <Button
                        android:id="@+id/btnDevolver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DEVOLVER"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#FFFFFF"
                        android:textColor="#000000"
                        android:stateListAnimator="@null"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#000000"
                        app:strokeWidth="1dp"
                        app:layout_constraintTop_toBottomOf="@id/tvDevolucaoLivro"
                        app:layout_constraintStart_toStartOf="parent"
                        android:onClick="onDevolverClick"/>

                    <TextView
                        android:id="@+id/tvMulta"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Valor da multa: R$ 0,00"
                        android:textSize="12sp"
                        app:layout_constraintTop_toBottomOf="@id/btnDevolver"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/ivCapaLivro" />

                    <ImageView
                        android:id="@+id/ivCapaLivro"
                        android:layout_width="100dp"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:src="@drawable/capadomquixote" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- SEÇÃO: LIVROS CURTIDOS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:text="Livros Curtidos"
                android:textStyle="bold"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Itens do Carrossel -->
                    <include android:id="@+id/livro1" layout="@layout/item_livro" />
                    <include android:id="@+id/livro2" layout="@layout/item_livro" />
                    <include android:id="@+id/livro3" layout="@layout/item_livro" />
                    <include android:id="@+id/livro4" layout="@layout/item_livro" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- SEÇÃO: MINHAS AVALIAÇÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:gravity="bottom">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Minhas Avaliações"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvQtdAvaliacoes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(5 avaliacoes)"
                    android:textSize="12sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                android:layout_margin="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Média e Estrelas Interativas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/background_campo_input"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvMediaNota"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.0"
                            android:textSize="24sp"
                            android:layout_marginEnd="16dp"
                            android:textColor="#000000"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView android:id="@+id/star1" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" />
                            <ImageView android:id="@+id/star2" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" />
                            <ImageView android:id="@+id/star3" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" />
                            <ImageView android:id="@+id/star4" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_on" />
                            <ImageView android:id="@+id/star5" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/btn_star_big_off" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Lista de Avaliações (Exemplo único conforme imagem) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thiago Narak"
                                android:textStyle="bold"
                                android:textSize="16sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="26/07/2025"
                                android:textSize="10sp"
                                android:textColor="#666666"/>
                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_star_big_on"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_star_big_on"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_star_big_on"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_star_big_on"/>
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@android:drawable/btn_star_big_off"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Star Wars"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Star wars!!!!"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/navbar_layout"/>

</LinearLayout>