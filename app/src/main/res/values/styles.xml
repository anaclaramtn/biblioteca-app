<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="botoesTelasIniciais" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#002D5E</item>
        <item name="backgroundTint">#FFFFFF</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="MenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>

        <!-- Espaçamento -->
        <item name="android:paddingVertical">20dp</item>
        <item name="android:paddingHorizontal">16dp</item>

        <!-- Texto maior -->
        <item name="android:textSize">20sp</item>

        <item name="android:background">@drawable/item_menu_background</item>
    </style>

    <style name="NavBar" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemBackground">@drawable/nav_item_background</item>
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="itemIconTint">@null</item>
        <item name="itemTextColor">@null</item>
        <item name="labelVisibilityMode">unlabeled</item>
    </style>
</resources>